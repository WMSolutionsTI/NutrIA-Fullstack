# ============================================================
# NutrIA-Pro — Frontend — Variáveis de Ambiente
# ============================================================
# Copie para .env.local e preencha com seus valores:
#   cp .env.example .env.local
# NUNCA commite o arquivo .env.local com valores reais!
# ============================================================

# URL da API Backend (VPS via Cloudflare Tunnel)
# Local: http://localhost:8000
# Produção: https://api.nutria-pro.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL pública do painel (opcional para redirecionamentos de OAuth no frontend)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nome da aplicação
NEXT_PUBLIC_APP_NAME=NutrIA-Pro
