# =============================================================================
# NutrIA-Pro — Variáveis de Ambiente para Produção (VPS)
# =============================================================================
# Copie para .env.prod e preencha com valores reais:
#   cp .env.prod.example .env.prod
# NUNCA commite o .env.prod com valores reais!
# =============================================================================

# ------------------------------------------------------------
# CLOUDFLARE TUNNEL
# ------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=seu-token-do-cloudflare-tunnel

# ------------------------------------------------------------
# CONTAINER REGISTRY
# ------------------------------------------------------------
REGISTRY=ghcr.io/wmsolutionsti
TAG=latest

# ------------------------------------------------------------
# POSTGRESQL — NutrIA-Pro
# ------------------------------------------------------------
POSTGRES_USER=nutriapro_app
POSTGRES_PASSWORD=troque-por-senha-forte-e-segura
POSTGRES_DB=nutriapro

# ------------------------------------------------------------
# REDIS — NutrIA-Pro
# ------------------------------------------------------------
REDIS_PASSWORD=troque-por-senha-forte-redis

# ------------------------------------------------------------
# RABBITMQ
# ------------------------------------------------------------
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=troque-por-senha-forte-rabbit

# ------------------------------------------------------------
# MINIO
# ------------------------------------------------------------
MINIO_ACCESS_KEY=nutrisaas
MINIO_SECRET_KEY=troque-por-senha-forte-minio

# ------------------------------------------------------------
# CHATWOOT
# ------------------------------------------------------------
CHATWOOT_POSTGRES_USER=chatwoot
CHATWOOT_POSTGRES_PASSWORD=troque-por-senha-forte-chatwoot
CHATWOOT_REDIS_PASSWORD=troque-por-senha-forte-chatwoot-redis
CHATWOOT_SECRET_KEY_BASE=troque-por-chave-secreta-longa-256-chars
