# =============================================================================
# NutrIA-Pro — Variáveis de Ambiente para Produção (VPS)
# =============================================================================
# Copie para .env.prod e preencha com valores reais:
#   cp .env.prod.example .env.prod
# NUNCA commite o .env.prod com valores reais!
# =============================================================================

# ------------------------------------------------------------
# CLOUDFLARE TUNNEL
# ------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=seu-token-do-cloudflare-tunnel

# ------------------------------------------------------------
# CONTAINER REGISTRY
# ------------------------------------------------------------
REGISTRY=ghcr.io/wmsolutionsti
TAG=latest

# ------------------------------------------------------------
# POSTGRESQL — NutrIA-Pro
# ------------------------------------------------------------
POSTGRES_USER=nutriapro_app
POSTGRES_PASSWORD=troque-por-senha-forte-e-segura
POSTGRES_DB=nutriapro

# ------------------------------------------------------------
# REDIS — NutrIA-Pro
# ------------------------------------------------------------
REDIS_PASSWORD=troque-por-senha-forte-redis

# ------------------------------------------------------------
# RABBITMQ
# ------------------------------------------------------------
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=troque-por-senha-forte-rabbit

# ------------------------------------------------------------
# MINIO
# ------------------------------------------------------------
MINIO_ACCESS_KEY=nutrisaas
MINIO_SECRET_KEY=troque-por-senha-forte-minio

# ------------------------------------------------------------
# CHATWOOT
# ------------------------------------------------------------
CHATWOOT_POSTGRES_USER=chatwoot
CHATWOOT_POSTGRES_PASSWORD=troque-por-senha-forte-chatwoot
CHATWOOT_REDIS_PASSWORD=troque-por-senha-forte-chatwoot-redis
CHATWOOT_SECRET_KEY_BASE=troque-por-chave-secreta-longa-256-chars

# ------------------------------------------------------------
# APP TOKENS E SEGURANÇA
# ------------------------------------------------------------
JWT_SECRET_KEY=troque-por-jwt-secret-forte
TOKEN_ENCRYPTION_SECRET=troque-por-secret-forte-para-criptografia

# ------------------------------------------------------------
# GOOGLE CALENDAR OAUTH
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=seu-google-client-id
GOOGLE_CLIENT_SECRET=seu-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://api.nutria-pro.com/api/v1/integracoes/google/callback

# ------------------------------------------------------------
# VOZ (TWILIO + RETELL)
# ------------------------------------------------------------
TWILIO_CALL_API_URL=https://api.twilio.com/...
TWILIO_API_TOKEN=token-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=twilio-auth-token
TWILIO_FROM_NUMBER=+5511999999999
VOICE_TWIML_URL=https://seu-endpoint-de-voice.xml
VOICE_STATUS_CALLBACK_URL=https://api.nutria-pro.com/api/v1/voz/twilio/webhook
TWILIO_VALIDATE_SIGNATURE=1
TWILIO_WEBHOOK_PUBLIC_URL=https://api.nutria-pro.com/api/v1/voz/twilio/webhook
RETELL_WEBHOOK_URL=https://api.retellai.com/...
RETELL_API_KEY=token-retell
ELEVENLABS_API_KEY=token-elevenlabs
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ------------------------------------------------------------
# CHATWOOT / ADMIN OPS
# ------------------------------------------------------------
CHATWOOT_URL=https://chat.nutria-pro.com
CHATWOOT_API_KEY=token-chatwoot
ADMIN_CHATWOOT_CONVERSATION_ID=1
ADMIN_CHATWOOT_CONTACTS=admin1,admin2
ADMIN_ALERT_WEBHOOK_URL=https://hooks.seu-monitor.com/nutria
ADMIN_ALERT_EMAIL=ops@nutria-pro.com
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USER=usuario-smtp
SMTP_PASSWORD=senha-smtp
SMTP_FROM=ops@nutria-pro.com
FRONTEND_URL=https://app.nutria-pro.com
