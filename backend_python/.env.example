TRIAL_PERIOD_DAYS=14

# ------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60              # por tenant
RATE_LIMIT_BURST=100

# ------------------------------------------------------------
# OBSERVABILIDADE
# ------------------------------------------------------------
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                        # json | text
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ------------------------------------------------------------
# INTELIGÊNCIA ARTIFICIAL — OpenAI
# ------------------------------------------------------------
OPENAI_API_KEY=sk-4p1_k3y_1234567890abcdef
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.7

# ------------------------------------------------------------
# AGENTE ESPECIALISTA — ANAMNESE E ENTREVISTA INICIAL
# ------------------------------------------------------------
ANAMNESE_AGENT_CONTEXT="Você é um especialista em anamnese nutricional e entrevista inicial. Seu objetivo é conduzir a coleta de informações de saúde, hábitos alimentares, histórico clínico e objetivos do paciente de forma empática, clara e precisa, seguindo as melhores práticas de nutrição e saúde."
ANAMNESE_AGENT_PROMPT="Realize a anamnese nutricional detalhada, faça perguntas relevantes sobre saúde, alimentação, rotina, histórico clínico e objetivos, e registre as respostas de forma organizada."

# ------------------------------------------------------------
