# ============================================================
# NutrIA-Pro — API — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores:
#   cp .env.example .env
#
# NUNCA commite o arquivo .env com valores reais!
# ============================================================

# ------------------------------------------------------------
# APLICAÇÃO
# ------------------------------------------------------------
APP_ENV=local                          # local | staging | production
APP_DEBUG=true                         # true apenas em local
APP_SECRET_KEY=2f8e1c4b7a9d6e3f5b1c8a7e2d4f6c3b
APP_ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://nutria-pro:U7v3rS3cUr3P4ssw0rd@localhost:5432/nutria-pro_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ------------------------------------------------------------
# CACHE — Redis
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_DEFAULT=3600                 # segundos

# ------------------------------------------------------------
# MESSAGE BROKER — RabbitMQ
# ------------------------------------------------------------
RABBITMQ_URL=amqp://nutria-pro:R4bb1tMQS3cUr3P4ssw0rd@localhost:5672/
RABBITMQ_EXCHANGE=nutria-pro.events
RABBITMQ_PREFETCH_COUNT=10

# ------------------------------------------------------------
# STORAGE — MinIO (S3-compatible)
# ------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=nutria-pro
MINIO_SECRET_KEY=QwErTyUiOp1234567890zxcvbnmASDF
MINIO_BUCKET_PLANS=planos-alimentares
MINIO_BUCKET_BACKUPS=db-backups
MINIO_USE_SSL=false                    # true em produção

# ------------------------------------------------------------
# AUTENTICAÇÃO — JWT
# ------------------------------------------------------------
JWT_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------
# CHATWOOT — Hub de Mensagens
# ------------------------------------------------------------
CHATWOOT_BASE_URL=http://localhost:3000
CHATWOOT_API_TOKEN=ch4tw00t_4p1_t0k3n_1234567890
CHATWOOT_WEBHOOK_TOKEN=w3bh00k_t0k3n_0987654321

# ------------------------------------------------------------
# EMAIL — SMTP
# ------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025                         # 1025 = MailHog local
SMTP_USER=nutria-pro
SMTP_PASSWORD=EmA1lS3cUr3P4ssw0rd
SMTP_FROM_EMAIL=noreply@nutria-pro.com
SMTP_USE_TLS=false                     # true em produção

# ------------------------------------------------------------
# PAGAMENTOS — Asaas
# ------------------------------------------------------------
ASAAS_API_KEY=asaas_4p1_k3y_1234567890
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3  # sandbox para local/staging
