# ============================================================
# NutrIA-Pro — .editorconfig
# https://editorconfig.org
# Garante consistência de estilo em todos os editores e IDEs
# ============================================================

root = true

# ------------------------------------------------------------
# Padrão global — aplica a todos os arquivos
# ------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# ------------------------------------------------------------
# Python — segue PEP 8 (4 espaços)
# ------------------------------------------------------------
[*.py]
indent_size = 4
max_line_length = 88

# ------------------------------------------------------------
# TypeScript / JavaScript / JSX / TSX
# ------------------------------------------------------------
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# ------------------------------------------------------------
# Estilos
# ------------------------------------------------------------
[*.{css,scss,sass,less}]
indent_size = 2

# ------------------------------------------------------------
# Markdown — não remover trailing whitespace
# (dois espaços no final = quebra de linha intencional)
# ------------------------------------------------------------
[*.{md,mdx}]
trim_trailing_whitespace = false
indent_size = 2

# ------------------------------------------------------------
# YAML — muito sensível a indentação
# ------------------------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# ------------------------------------------------------------
# JSON / JSONC
# ------------------------------------------------------------
[*.{json,jsonc}]
indent_size = 2

# ------------------------------------------------------------
# TOML
# ------------------------------------------------------------
[*.toml]
indent_size = 2

# ------------------------------------------------------------
# Shell scripts
# ------------------------------------------------------------
[*.sh]
indent_size = 2
end_of_line = lf

# ------------------------------------------------------------
# Makefile — OBRIGATÓRIO usar tabs
# ------------------------------------------------------------
[Makefile]
indent_style = tab

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
[Dockerfile*]
indent_size = 4

# ------------------------------------------------------------
# SQL
# ------------------------------------------------------------
[*.sql]
indent_size = 2
